{
  "info": {
    "name": "Padel Booking – External API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "API for the other mobile app: 1 court location (13 Padel). Set env: baseUrl, apiKey, locationId (e.g. SNLtAhHI5liqkjRnJehV)."
  },
  "variable": [
    {"key": "locationId", "value": "SNLtAhHI5liqkjRnJehV"}
  ],
  "item": [
    {
      "name": "Get Location",
      "request": {
        "method": "GET",
        "header": [{"key": "x-api-key", "value": "{{apiKey}}", "type": "text"}],
        "url": "{{baseUrl}}/getLocation?locationId={{locationId}}",
        "description": "Get one location (13 Padel – Reem Residence, Sheikh Zayed). Uses locationId from env or collection variable."
      }
    },
    {
      "name": "Get Slots",
      "request": {
        "method": "GET",
        "header": [{"key": "x-api-key", "value": "{{apiKey}}", "type": "text"}],
        "url": "{{baseUrl}}/getSlots?locationId={{locationId}}&date={{bookingDate}}",
        "description": "Get available slots per court for a date. Set bookingDate (YYYY-MM-DD) in env. Returns courts with availableSlots."
      }
    },
    {
      "name": "Create Booking",
      "request": {
        "method": "POST",
        "header": [
          {"key": "x-api-key", "value": "{{apiKey}}", "type": "text"},
          {"key": "Content-Type", "value": "application/json", "type": "text"}
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"locationId\": \"{{locationId}}\",\n  \"date\": \"{{bookingDate}}\",\n  \"courts\": {\n    \"court_1\": [\"10:00 AM\", \"10:30 AM\"]\n  },\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phoneNumber\": \"+1234567890\"\n}"
        },
        "url": "{{baseUrl}}/createBooking",
        "description": "Create a booking for 13 Padel. courts: court_1..court_4, slot strings from Get Slots. Use returned bookingId for Cancel."
      }
    },
    {
      "name": "Cancel Booking",
      "request": {
        "method": "DELETE",
        "header": [{"key": "x-api-key", "value": "{{apiKey}}", "type": "text"}],
        "url": "{{baseUrl}}/cancelBooking?bookingId=BOOKING_ID_FROM_CREATE",
        "description": "Cancel a booking. Use the bookingId returned from Create Booking."
      }
    }
  ]
}
